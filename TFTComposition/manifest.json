{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "TFT Composition Overlay",
    "author": "Antonio",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.230.0",
    "description": "Overlay de TFT para mostrar board, bench, shop y estado del jugador durante la partida.",
    "icon": "assets/IconMouseOver.png",
    "icon_gray": "assets/IconMouseNormal.png",
    "window_icon": "assets/WindowIcon.png"
  },
  "permissions": [
    "GameInfo",
    "GameControl"
  ],
  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [
        5426
      ]
    },
    "game_events": [
      5426
    ],
    "hotkeys": {
      "toggle_overlay": {
        "title": "Mostrar/Ocultar overlay",
        "action-type": "custom",
        "default": "Ctrl+Shift+Space",
        "passthrough": false,
        "game_ids": [
          5426
        ]
      }
    },
    "windows": {
      "background": {
        "file": "app/background.html",
        "is_background_page": true
      },
      "desktop": {
        "file": "app/desktop.html",
        "transparent": false,
        "show_in_taskbar": true,
        "show_minimize": true,
        "show_maximize": false,
        "resizable": true,
        "size": {
          "width": 1100,
          "height": 760
        }
      },
      "overlay": {
        "file": "app/overlay.html",
        "transparent": true,
        "show_in_taskbar": false,
        "show_minimize": false,
        "show_maximize": false,
        "resizable": true,
        "grab_keyboard_focus": false,
        "focus_game_takeover": "ReleaseOnHidden",
        "focus_game_takeover_release_hotkey": "toggle_overlay",
        "restrict_to_game_bounds": true,
        "size": {
          "width": 480,
          "height": 820
        }
      }
    }
  }
}
